{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=pastrydb;Username=postgres;Password=postgres;SSL Mode=Require;Trust Server Certificate=true"
  },
  
  "Jwt": {
    "SecretKey": "YOUR_SECRET_KEY_MUST_BE_AT_LEAST_64_CHARACTERS_LONG_AND_VERY_SECURE_USE_SECRETS_MANAGER",
    "Issuer": "PastryManager.Api",
    "Audience": "PastryManager.Client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "SigningAlgorithm": "HS512"
  },
  
  "Kafka": {
    "BootstrapServers": "localhost:9093",
    "SecurityProtocol": "SaslSsl",
    "SaslMechanism": "SCRAM-SHA-512",
    "SaslUsername": "kafka-user",
    "SaslPassword": "STORED_IN_SECRETS_MANAGER",
    "SslCaLocation": "/path/to/ca-cert",
    "SslCertificateLocation": "/path/to/client-cert",
    "SslKeyLocation": "/path/to/client-key",
    "SslKeyPassword": "STORED_IN_SECRETS_MANAGER",
    "ConsumerGroupId": "pastrymanager-consumer-group",
    "AutoOffsetReset": "earliest",
    "EnableAutoCommit": false,
    "Acks": "all",
    "MessageTimeoutMs": 30000,
    "RequestTimeoutMs": 30000,
    "EnableIdempotence": true,
    "AccountEventsTopic": "account-events",
    "TransactionEventsTopic": "transaction-events",
    "AuditLogTopic": "audit-logs",
    "DeadLetterTopic": "dead-letter-queue"
  },
  
  "Encryption": {
    "KmsKeyId": "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012",
    "Region": "us-east-1",
    "Algorithm": "SYMMETRIC_DEFAULT"
  },
  
  "AWS": {
    "Region": "us-east-1",
    "S3": {
      "BucketName": "pastrymanager-uploads",
      "ServiceURL": "",
      "ForcePathStyle": "false"
    }
  },
  
  "AllowedOrigins": [
    "https://yourdomain.com",
    "https://app.yourdomain.com"
  ],
  
  "FileUpload": {
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ "pdf", "docx", "xlsx", "png", "jpg", "jpeg", "txt", "csv" ]
  },
  
  "Security": {
    "RequireHttps": true,
    "RequireMfa": false,
    "MaxFailedLoginAttempts": 5,
    "LockoutDurationMinutes": 30,
    "PasswordPolicy": {
      "MinLength": 12,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireSpecialChar": true
    }
  }
}
