{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=pastrydb;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "SecretKey": "DEV_SECRET_KEY_FOR_JWT_TOKENS_MINIMUM_64_CHARS_LONG_CHANGE_IN_PROD",
    "Issuer": "PastryManager.Api",
    "Audience": "PastryManager.Client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "SigningAlgorithm": "HS512"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "SecurityProtocol": "Plaintext",
    "SaslMechanism": "Plain",
    "SaslUsername": "dev-user",
    "SaslPassword": "dev-password",
    "ConsumerGroupId": "pastrymanager-dev-group",
    "AutoOffsetReset": "earliest",
    "EnableAutoCommit": false,
    "Acks": "all",
    "MessageTimeoutMs": 30000,
    "RequestTimeoutMs": 30000,
    "EnableIdempotence": true,
    "AccountEventsTopic": "account-events",
    "TransactionEventsTopic": "transaction-events",
    "AuditLogTopic": "audit-logs",
    "DeadLetterTopic": "dead-letter-queue"
  },
  "Encryption": {
    "KmsKeyId": "alias/dev-key",
    "Region": "us-east-1",
    "Algorithm": "SYMMETRIC_DEFAULT"
  },
  "AWS": {
    "Region": "us-east-1",
    "S3": {
      "BucketName": "pastrymanager-uploads-dev",
      "ServiceURL": "http://localhost:4566",
      "ForcePathStyle": "true"
    }
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173",
    "https://localhost:5001"
  ],
  "FileUpload": {
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ "pdf", "docx", "xlsx", "png", "jpg", "jpeg", "txt", "csv" ]
  },
  "Security": {
    "RequireHttps": false,
    "RequireMfa": false,
    "MaxFailedLoginAttempts": 5,
    "LockoutDurationMinutes": 30
  }
}
